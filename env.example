 ── Launcher ──────────────────────────────────────────────────────────────────
LAUNCHER_PORT=5557

# ── MinIO object storage ──────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# ── Data DB ───────────────────────────────────────────────────────────────────
DATA_DB_USER=datauser
DATA_DB_PASSWORD=datapass
DATA_DB_NAME=timeseriesdb

# ── EIA API ───────────────────────────────────────────────────────────────────
EIA_API_KEY=your_eia_api_key_here

# ── Host path for shared DAGs folder ─────────────────────────────────────────
# Absolute path on THIS machine that maps to ./dags inside Airflow containers.
# Windows example: C:\Users\yourname\Desktop\airflow-launcher\dags
# Linux example:   /home/yourname/airflow-launcher/dags
HOST_DAGS_PATH=C:\Users\yourname\Desktop\airflow-launcher\dags

# ── Default model for scheduled pipeline runs ─────────────────────────────────
DEFAULT_MODEL_NAME=Chronos-2

# ── Pipeline schedule (cron, UTC) ─────────────────────────────────────────────
EIA_INGEST_CRON=30 8 * * *
PIPELINE_CRON=0 9 * * *
